<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/tab_alarm"
    tools:menu="@menu/tabs"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Alarm">

    <nl.joery.timerangepicker.TimeRangePicker
        android:id="@+id/picker"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.496"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.371"
        app:trp_endTime="6:30"
        app:trp_sliderRangeColor="#E1E1E1"
        app:trp_sliderRangeGradientEnd="#FB9F01"
        app:trp_sliderRangeGradientMiddle="#C27FA4"
        app:trp_sliderRangeGradientStart="#8281FA"
        app:trp_sliderWidth="12dp"
        app:trp_startTime="22:00"
        app:trp_thumbIconEnd="@drawable/alarm"
        app:trp_thumbIconStart="@drawable/moon" />

</androidx.constraintlayout.widget.ConstraintLayout>